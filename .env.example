# Mantra Bot Configuration Example
# Copy this file to .env and fill in your values

# ___ SESSION CONFIGURATION ___
# Put your Session ID below (Format: Mantra~GistID)
SESSION_ID=

# If you don't have a session id and prefer pairing code
PAIRING_NUMBER=254743032398

# ___ BOT CUSTOMIZATION ___
BOT_NAME=Mantra
BOT_OWNER="Midknight Mantra"
OWNER_NUMBER=254743032398
PACKNAME=Mantra
AUTHOR="Midknight Mantra"

# ___ SYSTEM CONFIGURATION ___
PORT=5000
PREFIXES=.,!,/,#
COMMAND_MODE=public
TIMEZONE=Africa/Nairobi
DESCRIPTION="High performance multi-device WhatsApp bot by Midknight Mantra"

# ___ API KEYS ___
REMOVEBG_KEY=
GIPHY_API_KEY=qnl7ssQChTdPjsKta2Ax2LMaGXz303tq

# ___ DATABASE CONFIGURATION ___
# Leave empty to use local JSON file storage (default)
# MongoDB Example: mongodb+srv://user:pass@cluster.mongodb.net/database
MONGO_URL=
# PostgreSQL Example: postgres://user:pass@localhost:5432/database
POSTGRES_URL=
# MySQL Example: mysql://user:pass@localhost:3306/database
MYSQL_URL=
# SQLite Example: ./data/mantra.db
DB_URL=

# ___ ADVANCED SETTINGS ___
MAX_STORE_MESSAGES=20
CLEANUP_INTERVAL=3600000
STORE_WRITE_INTERVAL=10000
